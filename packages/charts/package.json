{
  "name": "@viskit/charts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@viskit/animations": "workspace:*",
    "@viskit/core": "workspace:*",
    "@viskit/themes": "workspace:*",
    "d3-scale-chromatic": "^3.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/d3-array": "^3.2.1",
    "@types/d3-chord": "^3.0.6",
    "@types/d3-force": "^3.0.10",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/d3-shape": "^3.1.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@viskit/eslint-config": "workspace:*",
    "@viskit/tsconfig": "workspace:*",
    "d3-array": "^3.2.4",
    "d3-chord": "^3.0.1",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "d3-sankey": "^0.12.3",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.4.0",
    "typescript": "~6.0.2",
    "vitest": "^3.2.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
