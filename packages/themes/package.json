{
  "name": "@kodemaven/viskit-themes",
  "version": "0.1.0",
  "description": "Theme tokens, built-in themes, and CSS bridge for VisKit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kemi-Oluwadahunsi/Viskit-Charting-Library.git",
    "directory": "packages/themes"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["viskit", "theme", "react", "data-visualization", "design-tokens"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@viskit/eslint-config": "workspace:*",
    "@viskit/tsconfig": "workspace:*",
    "eslint": "^9.39.4",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "~6.0.2",
    "vitest": "^3.2.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
