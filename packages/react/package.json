{
  "name": "viskit-react",
  "version": "0.1.0",
  "description": "VisKit — composable React data visualization library (48 chart types)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kemi-Oluwadahunsi/Viskit-Charting-Library.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["viskit", "chart", "react", "d3", "svg", "data-visualization", "typescript"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@kodemaven/viskit-core": "workspace:*",
    "@kodemaven/viskit-charts": "workspace:*",
    "@kodemaven/viskit-themes": "workspace:*",
    "@kodemaven/viskit-animations": "workspace:*"
  },
  "devDependencies": {
    "@viskit/tsconfig": "workspace:*",
    "@viskit/eslint-config": "workspace:*",
    "eslint": "^9.39.4",
    "tsup": "^8.4.0",
    "typescript": "~6.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
